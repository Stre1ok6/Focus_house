# SiliconFlow（必填）：https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-ebhhlforwkmpmgbsrsrqyubamoghywqavqlnvcdhgievcauh

SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 须为控制台「视觉 / 多模态」列表里可用的模型 ID，例如：
# Qwen/Qwen2.5-VL-7B-Instruct
SILICONFLOW_MODEL=Qwen/Qwen3.5-35B-A3B

SILICONFLOW_TIMEOUT_SECONDS=120
SILICONFLOW_TEMPERATURE=0.2
SILICONFLOW_MAX_TOKENS=3000
# false=非思考模式；需要思考链时改为 true
SILICONFLOW_ENABLE_THINKING=false

# Flask（可选，仅在不改代码默认密钥时需要）
# FOCUS_APP_SECRET=请改为随机长字符串

# 以下 FOCUS_* 可选，不写则用代码里的默认值
# FOCUS_MAX_UPLOADS=30
# FOCUS_MAX_WORKERS=4
# FOCUS_MAX_IMAGE_EDGE=1800
